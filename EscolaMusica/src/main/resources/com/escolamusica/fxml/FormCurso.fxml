<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.escolamusica.controller.FormCursoController"
      spacing="15" style="-fx-background-color: #ecf0f1;">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Dados do Curso"
           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <Label text="Nome do Curso:"/>
    <TextField fx:id="txtNome" promptText="Nome do curso"/>

    <Label text="Preço Mensal (€):"/>
    <TextField fx:id="txtPreco" promptText="Ex: 45.00"/>

    <Label text="Tipo:"/>
    <TextField fx:id="txtTipo" promptText="Ex: Cursos Oficiais"/>

    <Label text="ID do Professor:"/>
    <TextField fx:id="txtIdProfessor" promptText="ID do professor"/>

    <Label text="ID do Instrumento:"/>
    <TextField fx:id="txtIdInstrumento" promptText="ID do instrumento"/>

    <Label fx:id="lblErro" text=""
           style="-fx-text-fill: #e74c3c;"/>

    <HBox spacing="10">
        <Button text="💾 Guardar" onAction="#handleGuardar"
                style="-fx-background-color: #27ae60; -fx-text-fill: white;
                       -fx-font-size: 13px; -fx-cursor: hand;"/>
        <Button text="❌ Cancelar" onAction="#handleCancelar"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                       -fx-font-size: 13px; -fx-cursor: hand;"/>
    </HBox>

</VBox>