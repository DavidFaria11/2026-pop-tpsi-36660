<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.escolamusica.controller.UCsProfessorController"
      spacing="15" style="-fx-background-color: #ecf0f1;">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="📚 As Minhas Unidades Curriculares"
           style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <TableView fx:id="tabelaUCs" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
            <TableColumn fx:id="colNome" text="Nome UC" prefWidth="200"/>
            <TableColumn fx:id="colDia" text="Dia" prefWidth="100"/>
            <TableColumn fx:id="colHora" text="Hora" prefWidth="100"/>
            <TableColumn fx:id="colCurso" text="Curso" prefWidth="180"/>
        </columns>
    </TableView>

</VBox>