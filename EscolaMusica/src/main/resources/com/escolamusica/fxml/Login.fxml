<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.escolamusica.controller.LoginController"
      alignment="CENTER" spacing="15"
      style="-fx-background-color: #2c3e50;">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <Label text="🎵 Escola de Música"
           style="-fx-font-size: 22px; -fx-text-fill: white; -fx-font-weight: bold;"/>

    <Label text="Sistema de Gestão"
           style="-fx-font-size: 13px; -fx-text-fill: #bdc3c7;"/>

    <TextField fx:id="txtUsername" promptText="Username"
               style="-fx-font-size: 14px; -fx-pref-width: 250px;"/>

    <PasswordField fx:id="txtPassword" promptText="Password"
                   style="-fx-font-size: 14px; -fx-pref-width: 250px;"/>

    <Label fx:id="lblErro" text=""
           style="-fx-text-fill: #e74c3c; -fx-font-size: 12px;"/>

    <Button text="Entrar" onAction="#handleLogin"
            style="-fx-background-color: #3498db; -fx-text-fill: white;
                   -fx-font-size: 14px; -fx-pref-width: 250px; -fx-cursor: hand;"/>

</VBox>