<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.escolamusica.controller.CursosController"
      spacing="15" style="-fx-background-color: #ecf0f1;">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="🎼 Gestão de Cursos"
               style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
        <Button text="+ Adicionar Curso" onAction="#handleAdicionar"
                style="-fx-background-color: #27ae60; -fx-text-fill: white;
                       -fx-font-size: 13px; -fx-cursor: hand;"/>
    </HBox>

    <TableView fx:id="tabelaCursos" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
            <TableColumn fx:id="colNome" text="Nome" prefWidth="180"/>
            <TableColumn fx:id="colPreco" text="Preço/Mês" prefWidth="100"/>
            <TableColumn fx:id="colTipo" text="Tipo" prefWidth="150"/>
            <TableColumn fx:id="colProfessor" text="Professor" prefWidth="150"/>
            <TableColumn fx:id="colInstrumento" text="Instrumento" prefWidth="120"/>
        </columns>
    </TableView>

    <HBox spacing="10">
        <Button text="✏️ Editar" onAction="#handleEditar"
                style="-fx-background-color: #3498db; -fx-text-fill: white;
                       -fx-font-size: 13px; -fx-cursor: hand;"/>
        <Button text="🗑️ Apagar" onAction="#handleApagar"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                       -fx-font-size: 13px; -fx-cursor: hand;"/>
    </HBox>

</VBox>